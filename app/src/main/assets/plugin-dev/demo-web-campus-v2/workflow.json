{
  "workflowId": "sync-schedule",
  "steps": [
    {
      "id": "ui",
      "type": "ui_emit",
      "uiAsset": "ui/schedule.json"
    },
    {
      "id": "web-note",
      "type": "message",
      "message": "该插件会打开受限 Web 页面，完成后回传 Web 数据包继续流程。"
    },
    {
      "id": "web-login",
      "type": "web_session",
      "sessionId": "login",
      "title": "插件网页登录演示",
      "urlTemplate": "{{baseUrl}}",
      "captureSelectors": ["title"],
      "extractCookies": true,
      "extractLocalStorage": true,
      "extractSessionStorage": true,
      "extractHtmlDigest": true
    },
    {
      "id": "schedule",
      "type": "schedule_emit_static",
      "scheduleAsset": "datapack/schedule.json",
      "updatedAtNow": true
    }
  ]
}

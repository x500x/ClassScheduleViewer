<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="4dp"
    android:background="@drawable/widget_bg_surface"
    android:minHeight="50dp"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="6dp"
        android:paddingEnd="12dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/course_nodes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#66707F"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/course_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#315F89"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/course_badge"
                android:layout_width="wrap_content"
                android:layout_height="16dp"
                android:background="@drawable/widget_bg_badge"
                android:gravity="center"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:textColor="#244E72"
                android:textSize="9sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/course_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#20242A"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/course_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#66707F"
            android:textSize="10sp" />
    </LinearLayout>
</LinearLayout>
